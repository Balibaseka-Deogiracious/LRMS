JWT_SECRET_KEY=your_super_secret_key_change_this_in_production_12345
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SMTP settings for registration verification and password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
SMTP_FROM=your_email@gmail.com

# Optional links included in email content
VERIFY_URL_BASE=http://localhost:8000/auth/verify-email
PASSWORD_RESET_URL_BASE=http://localhost:8000/auth/reset-password
